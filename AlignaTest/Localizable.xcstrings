{
  "sourceLanguage" : "en",
  "strings" : {
    "about.align_description" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Alynna helps you align your inner rhythm with the world around you, guided by context, not just intuition. A personalized rhythm card each day offers a short message with clear, actionable guidance to help you adjust your day." } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "Alynna 帮助你将内在节奏与周围世界对齐，由背景指导，而不仅仅是直觉。每天的个性化节奏卡提供简短信息和明确的可操作指导，帮助你调整你的一天。" } }
      }
    },
    "about.align_inner_rhythm" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Align Your Inner Rhythm" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "调整你的内在节奏" } }
      }
    },
    "about.activity" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Activity" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "活动" } }
      }
    },
    "about.activity_desc" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Take actions that match your current energy level, such as focus, slow down, or reset." } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "采取与你当前能量水平相匹配的行动，如专注、放慢或重置。" } }
      }
    },
    "about.career" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Career" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "职业" } }
      }
    },
    "about.career_desc" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Align your work style with the day, such as deep work, planning, or lighter tasks." } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "将你的工作风格与当天对齐，如深度工作、规划或轻松的任务。" } }
      }
    },
    "about.color" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Color" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "颜色" } }
      }
    },
    "about.color_desc" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Use specific colors to stabilize mood and support attention." } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "使用特定颜色来稳定情绪并支持注意力。" } }
      }
    },
    "about.copyright" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "© 2026 Alynna. Made with cosmic intention" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "© 2026 Alynna. 以宇宙之意创作" } }
      }
    },
    "about.eight_areas" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Eight Areas of Daily Support" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "八个日常支持领域" } }
      }
    },
    "about.gemstone" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Gemstone" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "宝石" } }
      }
    },
    "about.gemstone_desc" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Use symbolic objects as simple anchors for focus and steadiness." } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "使用象征性物品作为专注和稳定的简单锚点。" } }
      }
    },
    "about.gentle_description" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Alynna is not about prediction or pressure. It helps you make small, practical adjustments so you can move through the day with more clarity, balance, and ease." } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "Alynna 不关乎预测或压力。它帮助你做出小的实用调整，让你能以更清晰、平衡和从容的方式度过每一天。" } }
      }
    },
    "about.gentle_way" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "A Gentle Way to Move Through the Day" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "温和地度过每一天" } }
      }
    },
    "about.place" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Place" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "地点" } }
      }
    },
    "about.place_desc" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Choose or adjust your environment to improve focus, rest, or recovery." } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "选择或调整你的环境以改善专注、休息或恢复。" } }
      }
    },
    "about.privacy_chart" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Birth chart information remains private and secure" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "出生图表信息保持私密和安全" } }
      }
    },
    "about.privacy_control" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "You have full control over your data and can delete it anytime" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "你完全掌控自己的数据，可以随时删除" } }
      }
    },
    "about.privacy_description" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Your privacy is paramount. All sensor data is processed locally on your device. We do not collect, store, or share your personal information or location data." } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "你的隐私至关重要。所有传感器数据均在你的设备上本地处理。我们不收集、存储或共享你的个人信息或位置数据。" } }
      }
    },
    "about.privacy_location" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Location data is used only for local weather and cosmic calculations" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "位置数据仅用于本地天气和宇宙计算" } }
      }
    },
    "about.privacy_title" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Data & Privacy" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "数据与隐私" } }
      }
    },
    "about.privacy_transmission" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "No personal data is transmitted to external servers" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "没有个人数据传输至外部服务器" } }
      }
    },
    "about.relationship" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Relationship" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "关系" } }
      }
    },
    "about.relationship_desc" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Adjust how you engage with others, such as connect, hold space, or set boundaries." } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "调整你与他人互动的方式，如连接、给予空间或设定边界。" } }
      }
    },
    "about.scent" : {
      "localizations" : {
