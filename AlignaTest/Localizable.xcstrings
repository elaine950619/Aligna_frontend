    "profile.location_access_title" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Location Access"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "位置权限"
          }
        }
      }
    },
    "profile.location_dialog_message" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Location helps us understand your local context, including weather, humidity, pressure, and nearby environmental patterns such as greenery and built surroundings.\n\nWe store this information only to support your recommendations and continuity across the app. We do not share your location with other users or third parties.\n\nIf iOS opens the app settings page first, go to Location, then choose While Using the App or Always."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "位置信息帮助我们了解你所在地的环境，包括天气、湿度、气压，以及附近的植被与建筑环境。\n\n我们仅将此信息用于支持你的推荐与应用连贯性，不会与其他用户或第三方共享你的位置。\n\n如果 iOS 先打开应用设置页，请前往「位置」，选择「使用期间」或「始终」。"
          }
        }
      }
    },
    "profile.location_dialog_title" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
