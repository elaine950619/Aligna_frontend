    "about.gemstone_desc" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Use symbolic objects as simple anchors for focus and steadiness."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "使用象征性物品作为专注和稳定的简单锚点。"
          }
        }
      }
    },
    "about.gentle_description" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alynna is not about prediction or pressure. It helps you make small, practical adjustments so you can move through the day with more clarity, balance, and ease."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alynna 不关乎预测或压力。它帮助你做出小的实用调整，让你能以更清晰、平衡和从容的方式度过每一天。"
          }
        }
      }
    },
    "about.gentle_way" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A Gentle Way to Move Through the Day"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "温和地度过每一天"
          }
        }
      }
    },
