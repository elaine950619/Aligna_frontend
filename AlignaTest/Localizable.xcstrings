    "about.career_desc" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Align your work style with the day, such as deep work, planning, or lighter tasks."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "将你的工作风格与当天对齐，如深度工作、规划或轻松的任务。"
          }
        }
      }
    },
