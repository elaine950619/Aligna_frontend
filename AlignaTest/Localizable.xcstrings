    "about.privacy_description" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your privacy is paramount. All sensor data is processed locally on your device. We do not collect, store, or share your personal information or location data."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "你的隐私至关重要。所有传感器数据均在你的设备上本地处理。我们不收集、存储或共享你的个人信息或位置数据。"
          }
        }
      }
    },
