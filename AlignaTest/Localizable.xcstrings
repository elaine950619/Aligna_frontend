    "about.activity_desc" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A small act you can begin right now."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "一个小到可立即开始的动作。"
          }
        }
      }
    },
    "about.align_description" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alynna does not predict your future or judge your days.\n\nEach morning it invites you to pause — to listen to your body's rhythm, the temperature of your feelings, the quiet pull of the stars — and then meets you with one line of spirit, a set of small recommendations, and a focus for the day.\n\nIt isn't here to change you. It's here to help you see yourself more clearly."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alynna 不做预测，不给评判。\n\n它每天邀请你停下一秒，倾听自己——身体的节律、心情的温度、星象的细微牵引——再用一句心语、一组推荐、一天的课题，帮你与当下对齐。\n\n不是要改变你，只是让你更清楚地看见自己。"
          }
        }
      }
    },
    "about.align_inner_rhythm" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "What Alynna Is"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "什么是 Alynna"
          }
        }
      }
    },
    "about.alignment_body" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "At the top of today's mantra card, you'll see five stars and three keywords — this is Today's Alignment.\n\nAlignment is not a fortune. It measures how in sync you are with yourself and the day's natural rhythms, drawn from your current state, today's cosmic energy, and the focus you've chosen.\n\nA higher reading invites forward motion — a day when energy flows.\nA lower reading invites stillness, turning inward, restoring — a softer day.\n\nEvery day has its right note. Only its shape changes."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "折叠态的心语卡片上，你会看到五颗星与三个关键词——这是今日和度。\n\n它不是运势。和度衡量你今天与自己、与今日节律的同步程度，由你当下的状态、今日星象，以及你选择的课题共同汇成。\n\n高分邀请你向前——是能量流畅的日子。\n低分邀请你放缓、内收、休养——是一个更柔软的日子。\n\n每天都是恰到好处的节拍，只是形态不同。"
          }
        }
      }
    },
    "about.alignment_title" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Today's Alignment"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "今日和度"
          }
        }
      }
    },
