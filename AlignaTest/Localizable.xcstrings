    "about.activity_desc" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Take actions that match your current energy level, such as focus, slow down, or reset."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "采取与你当前能量水平相匹配的行动，如专注、放慢或重置。"
          }
        }
      }
    },
    "about.align_description" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alynna helps you align your inner rhythm with the world around you, guided by context, not just intuition. A personalized rhythm card each day offers a short message with clear, actionable guidance to help you adjust your day."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alynna 帮助你将内在节奏与周围世界对齐，由背景指导，而不仅仅是直觉。每天的个性化节奏卡提供简短信息和明确的可操作指导，帮助你调整你的一天。"
          }
        }
      }
    },
    "about.align_inner_rhythm" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Align Your Inner Rhythm"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "调整你的内在节奏"
          }
        }
      }
    },
    "about.career" : {
      "localizations" : {
