    "about.gemstone_desc" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "An anchor to keep or wear."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "静置或佩戴的能量锚。"
          }
        }
      }
    },
    "about.gentle_description" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alynna speaks softly. It does not hype, and it does not sell urgency.\n\nWe won't tell you what you \"must\" do today. We won't label your score as good or bad. We won't flood you with notifications.\n\nWe simply sit with you, for a moment, when you choose to open us."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alynna 的语气克制、不鼓吹、不贩卖焦虑。\n\n我们不会说「你今天一定要做什么」，不会给分数配「差/好」的标签，不会用通知轰炸你。\n\n只是每天在你愿意打开时，安静地陪你片刻。"
          }
        }
      }
    },
    "about.gentle_way" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A Gentle Way to Move Through the Day"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "温和地度过每一天"
          }
        }
      }
    },
    "about.moon_body" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Twice a month, when the new moon or full moon arrives, a quiet banner appears at the top of your card, inviting you to pause.\n\nThe new moon is for setting — write down three intentions you want to hold this month.\nThe full moon is for releasing — write down three things you're ready to let go of.\n\nWhat you write stays with you. It is your private pact with this month."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "每月两次，当新月或满月到来，Alynna 会在卡片顶端静静地出现一条横幅，邀请你停下来。\n\n新月是立心之时——写下你本月最想实现的三个意图。\n满月是放下之时——写下你愿意释放的三件事。\n\n你写下的话只留在你自己的地方。它们是你与这个月份的约定。"
          }
        }
      }
    },
    "about.moon_title" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The New Moon and the Full Moon"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "月圆与新月的仪式"
          }
        }
      }
    },
