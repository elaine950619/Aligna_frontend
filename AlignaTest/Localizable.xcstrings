    },
    "about.daily_flow_focus_desc" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pick one lens for the day, from 41 options — heartbreak, solitude, deep work, friendship, gratitude, a solar term, job search... It shapes the tone of your mantra and the direction of your recommendations."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "从 41 个候选中选一个作为今日的透镜——心碎、独处、深度专注、挚友、感恩、节气、求业……它决定了心语的语气，也决定了推荐的方向。"
          }
        }
      }
    },
    "about.daily_flow_focus_title" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Focus"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "今日课题"
          }
        }
      }
    },
    "about.daily_flow_intro" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Every morning, Alynna offers three things —"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "每一天，Alynna 给你三样东西——"
          }
        }
      }
    },
    "about.daily_flow_mantra_desc" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "One sentence that begins with \"I\" — a quiet promise or reminder drawn from your present state and today's focus, written in a restrained voice."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "一句以「我」开始的句子。是今天你对自己的承诺或提醒，摘自你当下的状态与课题，用内敛、克制的中文写成。"
          }
        }
      }
    },
    "about.daily_flow_mantra_title" : {
